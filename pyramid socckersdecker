#include <stdio.h>

int main() {
    int choice, rows;
    int p = 1;
    
    while (1) {
        if (p) {
            printf("MENU\n");
            printf("1. Right-Angle Triangle\n");
            printf("2. Inverted Right-Angle Triangle\n");
            printf("3. Pyramid\n");
            printf("4. Diamond\n");
            printf("5. Exit\n");
            p = 0;
        } else {
            printf("\nMENU\n");
            printf("1. Right-Angle Triangle\n");
            printf("2. Inverted Right-Angle Triangle\n");
            printf("3. Pyramid\n");
            printf("4. Diamond\n");
            printf("5. Exit\n");
        }
        
        printf("Enter your choice:\n");
        
        if (scanf("%d", &choice) != 1) {
            printf("\nInvalid choice. Please select a valid option.\n");
            continue;
        }
        
        if (choice < 1 || choice > 5) {
            printf("\nInvalid choice. Please select a valid option.\n");
            continue;
        }
        
        if (choice == 5) {
            printf("\nExiting the program. Thank you!\n");
            break;
        }
        
        printf("\nEnter the number of rows:\n");
        
        if (scanf("%d", &rows) != 1 || rows <= 0) {
            printf("\n\nPlease enter a positive integer for rows.\n");
            continue;
        }
        
        if (choice == 1) {
            for (int q = 1; q <= rows; q++) {
                for (int k = 1; k <= q; k++) {
                    printf("%d", k);
                    if (k < q) printf(" ");
                }
                printf("\n");
            }
        } else if (choice == 2) {
            for (int q = rows; q >= 1; q--) {
                for (int k = 1; k <= q; k++) {
                    printf("%d", k);
                    if (k < q) printf(" ");
                }
                printf("\n");
            }
        } else if (choice == 3) {
            for (int q = 1; q <= rows; q++) {
                for (int k = 0; k < rows - q; k++) {
                    printf(" ");
                }
                for (int k = 1; k <= q; k++) {
                    printf("%d", k);
                    if (k < q) printf(" ");
                }
                printf("\n");
            }
        } else if (choice == 4) {
            for (int q = 1; q <= rows; q++) {
                for (int k = 0; k < rows - q; k++) {
                    printf(" ");
                }
                for (int k = 1; k <= q; k++) {
                    printf("%d", k);
                    if (k < q) printf(" ");
                }
                printf("\n");
            }
            
            for (int q = rows - 1; q >= 1; q--) {
                for (int k = 0; k < rows - q; k++) {
                    printf(" ");
                }
                for (int k = 1; k <= q; k++) {
                    printf("%d", k);
                    if (k < q) printf(" ");
                }
                printf("\n");
            }
        }
    }
    
    return 0;
}
